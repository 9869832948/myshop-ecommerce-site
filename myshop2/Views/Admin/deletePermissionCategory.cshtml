@model Category
<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">Are Sure Want to Delete This Category?</h2>
</div>
<div class="col-md-2"></div>
<div class="col-md-8">
    <ul class="list-group my-3">
        <li class="list-group-item">Customer Id : @Model.category_id</li>
        <li class="list-group-item">Customer Name : @Model.category_name</li>
       
    </ul>
    <a href="@Url.Action("deleteCategory", "Admin", new { id = Model.category_id })" class="btn btn-danger">Delete Category</a>
    <a href="@Url.Action("fetchCategory", "Admin")" class="btn btn-warning">Back To List</a>
</div>
<div class="col=md-2"></div>