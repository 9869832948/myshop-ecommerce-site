
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
        background-color: #f5f7fb;
        }

        .card {
        border: none;
        border-radius: 12px;
        }
    </style>
</head>

<body>

    <div class="container py-4">

        <!-- Title -->
        <div class="mb-4">
            <h2>Admin Dashboard</h2>
        </div>

        <!-- Stats Cards -->
        <div class="row g-3 mb-4">

            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h6>Total Revenue</h6>
                    <h4>$18,500</h4>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h6>Total Orders</h6>
                    <h4>720</h4>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h6>Products</h6>
                    <h4>180</h4>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h6>Customers</h6>
                    <h4>2,150</h4>
                </div>
            </div>

        </div>

        <!-- Charts -->
        <div class="row mb-4">

            <div class="col-md-8">
                <div class="card p-3 shadow-sm">
                    <h6>Sales Analytics</h6>
                    <canvas id="salesChart"></canvas>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3 shadow-sm">
                    <h6>Order Status</h6>
                    <canvas id="orderChart"></canvas>
                </div>
            </div>

        </div>

        <!-- Tables + Lists -->
        <div class="row">

            <!-- Orders -->
            <div class="col-md-7">
                <div class="card p-3 shadow-sm">
                    <h6>Recent Orders</h6>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>#201</td>
                                <td>Ram</td>
                                <td><span class="badge bg-success">Completed</span></td>
                                <td>$250</td>
                            </tr>
                            <tr>
                                <td>#202</td>
                                <td>Sita</td>
                                <td><span class="badge bg-warning">Pending</span></td>
                                <td>$180</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Top Products -->
            <div class="col-md-5">
                <div class="card p-3 shadow-sm">
                    <h6>Top Products</h6>
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between">
                            iPhone <span>$6000</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            Laptop <span>$4200</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            Shoes <span>$1500</span>
                        </li>
                    </ul>
                </div>
            </div>

        </div>

    </div>

    <script>
        // Sales Chart
        new Chart(document.getElementById('salesChart'), {
        type: 'line',
        data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun'],
        datasets: [{
        label: 'Revenue',
        data: [3000, 4000, 3500, 5000, 4500, 6000],
        borderColor: 'blue',
        fill: false
        }]
        }
        });

        // Order Chart
        new Chart(document.getElementById('orderChart'), {
        type: 'doughnut',
        data: {
        labels: ['Completed', 'Pending', 'Cancelled'],
        datasets: [{
        data: [65, 20, 15],
        backgroundColor: ['green','orange','red']
        }]
        }
        });
    </script>

</body>
</html>
